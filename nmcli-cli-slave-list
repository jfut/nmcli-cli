usage() {
    cat << _EOF_
Usage:
    $0 IF_NAME

    Examples:
        $0 bond1
        $0 vlan.100
        $0 br1

_EOF_
}

slave_list() {
    local IF_NAME=${1:-}
    local i

    # Find lower interfaces
    TARGET="/sys/class/net/${IF_NAME}/"
    if [[ -e "${TARGET}" ]]; then
        for i in "${TARGET}"/lower_*; do
            [[ -e "${i}" ]] || continue
            echo "${i##*/lower_}"
        done
    fi
}

# Main
main() {
    [[ $# -lt 1 ]] && usage && exit 1

    slave_list "${@}"
}

[[ ${#BASH_SOURCE[@]} = 1 ]] && main "${@}"
